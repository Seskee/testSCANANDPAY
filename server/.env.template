# ============================================================
# QUICKPAY — server/.env
# Spremi ovu datoteku kao: server/.env
# NIKAD ne commitaj .env u Git!
# ============================================================

# ──────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────
# POSTGRESQL BAZA
# ──────────────────────────────────────────
# Format: postgresql://KORISNIK:LOZINKA@HOST:PORT/IME_BAZE
#
# KORISNIK  — username u PostgreSQL-u (default je "postgres")
# LOZINKA   — lozinka koju si postavio pri instalaciji
# HOST      — localhost (jer je na tvom PC-u)
# PORT      — 5432 (default PostgreSQL port)
# IME_BAZE  — "quickpay" (baza koju si kreirao)
#
DATABASE_URL=postgresql://postgres:OVDJE_STAVI_SVOJU_LOZINKU@localhost:5432/quickpay

# ──────────────────────────────────────────
# JWT TOKENI
# ──────────────────────────────────────────
# Generiraj random string u terminalu:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Pokreni dva puta — svaki tajni ključ mora biti različit!
#
JWT_SECRET=ZAMIJENI_OVO_S_RANDOM_STRINGOM_128_ZNAKOVA
REFRESH_TOKEN_SECRET=ZAMIJENI_I_OVO_S_DRUGIM_RANDOM_STRINGOM

# ──────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────
# Ključevi s: https://dashboard.stripe.com/test/apikeys
# Za development UVIJEK koristi test ključeve (sk_test_...)
#
STRIPE_SECRET_KEY=sk_test_TVOJ_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_TVOJ_WEBHOOK_SECRET

# ──────────────────────────────────────────
# FRONTEND URL
# ──────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ──────────────────────────────────────────
# EMAIL (opcionalno — projekt radi i bez ovoga)
# ──────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tvoj.email@gmail.com
EMAIL_PASSWORD=tvoj_gmail_app_password
EMAIL_FROM=noreply@quickpay.app
