# Server Configuration
PORT=3000

# Database Configuration
# For local MongoDB: mongodb://localhost/QuickPay
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/QuickPay
DATABASE_URL=mongodb://localhost/QuickPay

# JWT Configuration
# Generate secure random strings for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random_123456789
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_also_make_it_long_and_random_987654321

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/test/apikeys
# Use test keys (sk_test_...) for development
# Use live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Email Configuration (Optional - falls back to test mode if not configured)
# For Gmail: Enable "Less secure app access" or use App Password
# For SendGrid: Use your SendGrid API key
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@scanandpay.com

# Development Notes:
# - The app works without email configuration (uses test mode)
# - Stripe test mode allows testing without real money
# - MongoDB can be local or cloud-based (MongoDB Atlas)
# - Generate strong JWT secrets for production using crypto
